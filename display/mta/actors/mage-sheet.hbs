{{!-- Mage: the Ascension Sheet Header --}}
<header class="actor-header" {{#if headerbg}} style="background: url({{headerbg}}) center;"{{/if}}>
    <div class="header-fields">
        <div class="header-fields-left">
            {{> "systems/wod5e/display/shared/actors/parts/health.hbs"}}
            {{> "systems/wod5e/display/shared/actors/parts/willpower.hbs"}}
        </div>
    </div>

    {{> "systems/wod5e/display/shared/actors/parts/header-profile.hbs"}}

    <div class="header-fields">
        <div class="header-fields-right">
            <div class="flexcol">

                {{!-- Paradox: 0–5 dot track. The burst icon next to the label triggers
                     a Backlash roll; the d10 button rolls a quick Paradox Check
                     (Rouse-style, opens dice/difficulty/roll-mode dialog). --}}
                <div class="flexcol field-section">
                    <label class="resource-label field-header">
                        {{localize "WOD5E.MTA.Paradox"}}
                        <a class="rollable paradox-backlash-trigger" data-action="paradoxBacklashRoll"
                            title="{{localize 'WOD5E.MTA.ParadoxBacklashTitle'}}">
                            <i class="fa-solid fa-burst"></i>
                        </a>
                    </label>
                    <div class="flexrow">
                        {{> "systems/wod5e/display/mta/actors/parts/paradox.hbs"}}
                        <button class="rollable paradox-roll-btn" data-action="paradoxRoll" type="button"
                            title="{{localize 'WOD5E.MTA.ParadoxRollTitle'}}">
                            <i class="fa-solid fa-dice-d10"></i>
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</header>
