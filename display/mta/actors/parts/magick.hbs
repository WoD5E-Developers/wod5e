{{!-- Magick Tab: Arete, Paradox, Permanent Paradox, Quiet (squares), Hubris (squares) --}}
<section class="tab {{tab.cssClass}}" data-tab="{{tab.id}}" data-group="{{tab.group}}">
    <div class="flexrow">

        {{!-- Left: Arete + Paradox tracks --}}
        <div class="flexcol">

            {{!-- Arete (dots 1–10) --}}
            <div class="flex-group-center nogrow">
                <div class="flexcol resource">
                    <label class="resource-label field-header">{{localize "WOD5E.MTA.Arete"}}</label>
                    <div class="resource-content flexrow flex-center flex-between">
                        <div class="resource-value" data-value="{{arete}}" data-name="system.arete">
                            <span class="resource-value-empty" data-action="dotCounterEmpty"></span>
                            {{#numLoop 10}}
                            <span class="resource-value-step" data-action="dotCounterChange" data-index="{{this}}"></span>
                            {{/numLoop}}
                        </div>
                    </div>
                    <div class="resource-hint">{{localize "WOD5E.MTA.AreteHint"}}</div>
                </div>
            </div>

            {{!-- Paradox (dots 0–5) --}}
            <div class="flex-group-center nogrow">
                <div class="flexcol resource">
                    <label class="resource-label field-header">{{localize "WOD5E.MTA.Paradox"}}</label>
                    <div class="resource-content flexrow flex-center flex-between">
                        <div class="resource-value" data-value="{{paradox.value}}" data-name="system.paradox.value">
                            <span class="resource-value-empty" data-action="dotCounterEmpty"></span>
                            {{#numLoop paradox.max}}
                            <span class="resource-value-step" data-action="dotCounterChange" data-index="{{this}}"></span>
                            {{/numLoop}}
                        </div>
                    </div>
                </div>
            </div>

            {{!-- Permanent Paradox (dots 0–5) --}}
            <div class="flex-group-center nogrow">
                <div class="flexcol resource">
                    <label class="resource-label field-header">{{localize "WOD5E.MTA.PermanentParadox"}}</label>
                    <div class="resource-content flexrow flex-center flex-between">
                        <div class="resource-value" data-value="{{permanentParadox.value}}" data-name="system.permanentParadox.value">
                            <span class="resource-value-empty" data-action="dotCounterEmpty"></span>
                            {{#numLoop permanentParadox.max}}
                            <span class="resource-value-step" data-action="dotCounterChange" data-index="{{this}}"></span>
                            {{/numLoop}}
                        </div>
                    </div>
                    <div class="resource-hint">{{localize "WOD5E.MTA.PermanentParadoxHint"}}</div>
                </div>
            </div>

        </div>

        {{!-- Right: Absorb Quintessence + Quiet + Hubris squares --}}
        <div class="flexcol">

            {{!-- Absorb Quintessence button --}}
            <div class="flex-group-center nogrow">
                <div class="flexcol resource">
                    <label class="resource-label field-header">{{localize "WOD5E.MTA.Quintessence"}}</label>
                    <div class="flexrow flex-center">
                        <button class="rollable" data-action="absorbQuintessence" type="button">
                            <i class="fa-solid fa-arrow-down-to-line"></i>
                            {{localize "WOD5E.MTA.AbsorbQuintessence"}}
                        </button>
                    </div>
                    <div class="resource-hint">
                        {{localize "WOD5E.MTA.QuintessencePerRoll"}}: {{quintessencePerRoll}}
                        ({{localize "WOD5E.MTA.AretePlusPrime"}})
                    </div>
                </div>
            </div>

            {{!-- Quiet (squares 0–5) --}}
            <div class="flex-group-center nogrow">
                <div class="flexcol resource">
                    <label class="resource-label field-header">{{localize "WOD5E.MTA.Quiet"}}</label>
                    <div class="resource resource-content flexrow flex-group-center flex-between">
                        <div class="resource-counter editable mta-integrity" data-states="-:value"
                            data-value="{{quiet.value}}" data-name="system.quiet">
                            {{#numLoop quiet.max}}
                            <span class="resource-counter-step" data-action="squareCounterChange"
                                data-index="{{this}}" data-state=""></span>
                            {{/numLoop}}
                        </div>
                    </div>
                </div>
            </div>

            {{!-- Hubris (squares 0–5) --}}
            <div class="flex-group-center nogrow">
                <div class="flexcol resource">
                    <label class="resource-label field-header">{{localize "WOD5E.MTA.Hubris"}}</label>
                    <div class="resource resource-content flexrow flex-group-center flex-between">
                        <div class="resource-counter editable mta-integrity" data-states="-:value"
                            data-value="{{hubris.value}}" data-name="system.hubris">
                            {{#numLoop hubris.max}}
                            <span class="resource-counter-step" data-action="squareCounterChange"
                                data-index="{{this}}" data-state=""></span>
                            {{/numLoop}}
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
