{{!-- Spend Quintessence button — triggers Paradox Checks equal to points spent.
     Shows (Arete + Prime) as the per-roll maximum so the player always knows their pool. --}}
<button class="rollable quintessence-button" data-action="spendQuintessence" type="button"
    title="{{localize 'WOD5E.MTA.SpendQuintessence'}} ({{localize 'WOD5E.MTA.MaxPerRoll'}}: {{quintessencePerRoll}})">
    <i class="fa-solid fa-wand-sparkles"></i>
</button>
