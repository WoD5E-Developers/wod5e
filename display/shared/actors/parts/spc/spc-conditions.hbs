<div class="description-field">
    <div class="flexrow flex-center field-header">
        <label class="resource-label item-name">
            {{localize "WOD5E.ItemsList.Conditions"}}
        </label>
        <div class="item-controls">
            <a class="item-control search-data-item flex-center" data-action="searchItem" title="{{localize 'WOD5E.Search'}}" data-type="condition">
                <i class="fa-solid fa-magnifying-glass"></i>
            </a>
            <a class="item-control item-create" data-action="createItem" title="{{localize 'WOD5E.Add'}}" data-type="condition">
                <i class="fas fa-plus"></i>
            </a>
        </div>
    </div>
    <div class="description-content resource list-resource">
        <div class="items-list flexcol">
            {{#each conditions as |condition id|}}
                <div class="collapsible-container">
                    <div class="item flexrow{{#if condition.system.suppressed}} suppressed{{/if}}" data-drag="true" data-item-id="{{condition.id}}" data-document-uuid="{{condition.uuid}}" data-type="Item">
                        <div class="item-image clickable" data-action="itemChat" data-item-id="{{condition._id}}">
                            <img src="{{condition.img}}" title="{{condition.name}}" width="24" height="24" alt="{{condition.name}}" />
                        </div>
                        <div class="item-name{{#if condition.system.enrichedDescription}} collapsible{{/if}}" {{#if condition.system.enrichedDescription}}data-action="toggleCollapse"{{/if}}>
                            {{condition.name}}
                        </div>
                        <div class="item-controls">
                            <a class="item-control item-edit" data-action="itemOpen" data-item-id="{{condition._id}}" title="{{localize 'WOD5E.Edit'}}"><i
                                class="fas fa-edit"></i></a>
                            <a class="item-control condition-suppression" data-action="toggleConditionSuppression" data-item-id="{{condition._id}}" title="{{localize 'WOD5E.ItemsList.ToggleConditionSuppression'}}"><i
                                class="fa-solid {{#if condition.system.suppressed}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i></a>
                            <a class="item-control item-delete" data-action="itemDelete" data-item-id="{{condition._id}}" title="{{localize 'WOD5E.Delete'}}"><i
                                class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    <div class="collapsible-content trait-description">
                        {{{condition.system.enrichedDescription}}}
                    </div>
                </div>
            {{/each}}
        </div>
    </div>
</div>
