<div class="dice-group-header flex-group-center">
  {{#unless disableBasicDice}}
    <label>{{localize 'WOD5E.MTA.MageDice'}}</label>
  {{/unless}}
  {{#unless disableAdvancedDice}}
    <label>{{localize 'WOD5E.MTA.ParadoxDice'}}</label>
  {{/unless}}
</div>
<div class="base-dice-group flex-group-center">
  {{#unless disableBasicDice}}
    <div class="basic-dice">
      <div class="dice-input">
        <img width="50" height="50" src="systems/wod5e/assets/icons/dialog/mortal-dice.png"/>
        <div class="flexrow">
          <i class="fas fa-minus dialog-control dialog-minus" data-action="minus" data-resource="inputBasicDice"></i>
          <input type="number" min="0" id="inputBasicDice" value="{{basicDice}}">
          <i class="fas fa-plus dialog-control dialog-plus" data-action="plus" data-resource="inputBasicDice"></i>
        </div>
      </div>
    </div>
  {{/unless}}
  {{#unless disableAdvancedDice}}
    <div class="advanced-dice">
      <div class="dice-input">
        <img width="50" height="50" src="systems/wod5e/assets/icons/dialog/hunger-dice.png"
             style="filter: hue-rotate(200deg) saturate(1.5);"/>
        <div class="flexrow">
          <i class="fas fa-minus dialog-control dialog-minus" data-action="minus" data-resource="inputAdvancedDice"></i>
          <input type="number" min="0" id="inputAdvancedDice" value="{{advancedDice}}">
          <i class="fas fa-plus dialog-control dialog-plus" data-action="plus" data-resource="inputAdvancedDice"></i>
        </div>
      </div>
    </div>
  {{/unless}}
</div>
{{> "systems/wod5e/display/ui/parts/roll-dialog-base.hbs"}}
